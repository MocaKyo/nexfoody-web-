    "firebase-functions": "^5.0.0",
    "mercadopago": "^2.12.0",
    "stripe": "^16.0.0"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "firebase-functions-test": "^3.2.0",
    "typescript": "^5.3.3"
  },
  "private": true
}
